{
	"name": "@khang07/zing-mp3-api",
	"version": "1.4.0",
	"author": "GiaKhang <ngkhang9a5lqc11@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/GiaKhang1810/zing-mp3-api.git"
	},
	"type": "module",
	"main": "./dist/cjs/index.cjs",
	"module": "./dist/esm/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"require": "./dist/cjs/index.cjs",
			"default": "./dist/esm/index.js"
		}
	},
	"bugs": {
		"url": "https://github.com/GiaKhang1810/zing-mp3-api/issues"
	},
	"description": "The basic APIs provide the features of ZingMp3",
	"homepage": "https://github.com/GiaKhang1810/zing-mp3-api#readme",
	"keywords": [
		"zingmp3",
		"zing",
		"mp3",
		"zing-api",
		"zing-mp3-api"
	],
	"license": "MIT",
	"scripts": {
		"build:esm": "tsc -p tsconfig.json",
		"build:cjs": "rollup -c",
		"build": "rm -rf dist && npm run build:esm && npm run build:cjs && rm -rf dist/esm/types dist/cjs/types",
		"test": "mocha"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"mocha": "^11.7.5",
		"rollup": "^4.60.1",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"axios": "^1.14.0",
		"m3u8stream": "^0.8.6"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	]
}